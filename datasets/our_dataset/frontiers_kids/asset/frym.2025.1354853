        let ibarAboutOpen = searchModuleRoot.querySelector('.Ibar__dropdown__trigger--open');
        let IbarMain = searchModuleRoot.querySelector('.Ibar__main');

        $(IbarSubmit).attr('data-event', 'navigation-bar-submit');

    </script>

</body>
</html>